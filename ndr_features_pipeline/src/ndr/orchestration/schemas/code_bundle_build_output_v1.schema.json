{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ndr/contracts/code_bundle_build_output_v1.schema.json",
  "title": "code_bundle_build_output.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "project_name",
    "feature_spec_version",
    "artifact_build_id",
    "artifact_sha256",
    "artifact_format",
    "step_artifacts"
  ],
  "properties": {
    "contract_version": {
      "type": "string",
      "const": "code_bundle_build_output.v1"
    },
    "project_name": {
      "type": "string",
      "minLength": 1
    },
    "feature_spec_version": {
      "type": "string",
      "minLength": 1
    },
    "artifact_build_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "artifact_format": {
      "type": "string",
      "const": "tar.gz"
    },
    "step_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/stepArtifact"
      }
    }
  },
  "definitions": {
    "stepArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_family",
        "pipeline_job_name",
        "step_name",
        "entry_script",
        "code_artifact_s3_uri",
        "artifact_build_id",
        "artifact_sha256",
        "artifact_format"
      ],
      "properties": {
        "artifact_family": {
          "type": "string",
          "enum": [
            "streaming",
            "dependent",
            "fg_b_baseline",
            "unload",
            "inference",
            "join",
            "training",
            "backfill"
          ]
        },
        "pipeline_job_name": {
          "type": "string",
          "enum": [
            "pipeline_15m_streaming",
            "pipeline_15m_dependent",
            "pipeline_fg_b_baseline",
            "pipeline_machine_inventory_unload",
            "pipeline_inference_predictions",
            "pipeline_prediction_feature_join",
            "pipeline_if_training",
            "pipeline_backfill_historical_extractor",
            "pipeline_backfill_15m_reprocessing"
          ]
        },
        "step_name": {
          "type": "string",
          "minLength": 1
        },
        "entry_script": {
          "type": "string",
          "pattern": "^(?!/)(?!.*\\.\\.)(?!.*//).+\\.py$"
        },
        "code_artifact_s3_uri": {
          "type": "string",
          "pattern": "^s3://[^\\s]+$"
        },
        "artifact_build_id": {
          "type": "string",
          "minLength": 1
        },
        "artifact_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "artifact_format": {
          "type": "string",
          "const": "tar.gz"
        }
      }
    }
  }
}
